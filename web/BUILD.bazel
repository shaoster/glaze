load("@aspect_rules_js//js:defs.bzl", "js_binary", "js_library", "js_run_binary", "js_test")
load("@npm//:defs.bzl", "npm_link_all_packages")
load("@npm//web:vite/package_json.bzl", vite_pkg = "bin")
load("@npm//web:vitest/package_json.bzl", vitest_pkg = "bin")
load("@npm//web:typescript/package_json.bzl", typescript_pkg = "bin")
load("@npm//web:eslint/package_json.bzl", eslint_pkg = "bin")

# Link all npm packages into this package's node_modules so that js_binary
# and js_run_binary targets can resolve imports at build time.
npm_link_all_packages(name = "node_modules")

exports_files(["eslint.config.js"])

# Public eslint binary used by the lint aspect in //:lint.bzl
eslint_pkg.eslint_binary(name = "eslint_bin", visibility = ["//visibility:public"])

# ── Step 1: OpenAPI JSON schema ───────────────────────────────────────────────
# Runs manage.py spectacular via the Python genrule tool.
# Output: openapi.json
#
# Cache behaviour: re-runs only when api/**, backend/**, or workflow_files
# change (transitively through //tools:generate_schema's deps).

genrule(
    name = "openapi_schema",
    outs = ["openapi.json"],
    tools = ["//tools:generate_schema"],
    cmd = "$(execpath //tools:generate_schema) $@",
    visibility = ["//visibility:public"],
)

# ── Step 2: TypeScript generated types ───────────────────────────────────────
# Runs generate-types.mjs with the openapi.json as input.
# Output: generated-types.ts written to frontend_common/src/.
#
# Cache behaviour: re-runs only when openapi.json content changes — so a
# backend change that doesn't affect the public API surface leaves this output
# (and all web targets downstream) with a cache hit.

js_binary(
    name = "generate_types_bin",
    entry_point = "scripts/generate-types.mjs",
    data = [
        ":node_modules/openapi-typescript",
        ":node_modules/typescript",
    ],
    visibility = ["//visibility:public"],
)

# ── npm tool binaries ─────────────────────────────────────────────────────────
# Generated js_run_binary-compatible targets for each npm CLI tool.
# These macros create the js_binary + entry_point wiring via directory_path
# so the Node toolchain is resolved correctly and node is on PATH.

vite_pkg.vite(name = "vite_run", srcs = [":web_lib"], out_dirs = ["dist"], args = ["build"], chdir = package_name())
typescript_pkg.tsc(name = "tsc_run", srcs = [":web_lib"], stdout = "tsc_check.log", args = ["--noEmit"], chdir = package_name(), tags = ["lint"])
eslint_pkg.eslint(name = "eslint_run", srcs = [":web_lib", "eslint.config.js"], stdout = "eslint_check.log", args = ["."], chdir = package_name(), tags = ["lint"])

# ── Web source library ────────────────────────────────────────────────────────

js_library(
    name = "web_lib",
    srcs = glob(
        [
            "src/**/*.ts",
            "src/**/*.tsx",
            "src/**/*.css",
            "src/**/*.svg",
            "*.json",
            "*.config.*",
            "*.ts",
            "index.html",
            "public/**",
        ],
        exclude = [
            "src/**/*.test.ts",
            "src/**/*.test.tsx",
        ],
    ),
    deps = [
        ":node_modules",
        "//frontend_common:frontend_common_lib",
        "//frontend_common:generated_types",
    ],
    visibility = ["//visibility:public"],
)

# ── Component source libraries ────────────────────────────────────────────────
# Fine-grained js_library targets for test isolation: each test target depends
# only on the components it exercises, so changing one component does not
# invalidate unrelated test targets.
#
# Dependency relationships mirror the actual import graph so Bazel tracks
# changes correctly. web_lib (used for build) remains the authoritative
# all-sources target; these are testing-only slices of the same source tree.

# Config files needed by every test target (tsconfig, package.json, etc.)
js_library(
    name = "web_test_configs",
    srcs = [
        "tsconfig.json",
        "tsconfig.app.json",
        "tsconfig.node.json",
        "tsconfig.test.json",
        "package.json",
        "vitest.config.ts",
        "src/test-setup.ts",
        "src/yaml.d.ts",
        "src/cloudinary-widget.d.ts",
    ],
    deps = [":node_modules"],
)

# Leaf components: no local component deps.
