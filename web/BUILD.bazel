    name = "primitive_src",
    srcs = [
        "src/components/StateChip.tsx",
        "src/components/ErrorBoundary.tsx",
        "src/components/TagChip.tsx",
        "src/components/tagPalette.ts",
        "src/components/globalFieldPickerUtils.ts",
        "src/components/thumbnailConstants.ts",
