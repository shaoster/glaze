# Copy this file to .env on the droplet and fill in every value.
# Never commit .env to version control.

# Django secret key — generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=

# PostgreSQL password — choose a strong random string
POSTGRES_PASSWORD=

# The hostname of your droplet (no protocol, no trailing slash)
# e.g. myapp.example.com  or  123.45.67.89
ALLOWED_HOST=

# The full origin URL that the browser will use to reach the app
# e.g. https://myapp.example.com  or  http://123.45.67.89:8000
APP_ORIGIN=

# Google OAuth (optional — leave blank to disable Google sign-in)
# GOOGLE_OAUTH_CLIENT_ID is used by Django at runtime to verify Google JWTs.
# The frontend bundle also reads this variable to render the Google Login button.
GOOGLE_OAUTH_CLIENT_ID=

# Cloudflare R2 object storage (image/video/audio assets)
# All five are required for uploads, the eager crop pipeline, and showcase
# video hosting; leave blank to disable uploads (stored URLs still render).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Public CDN base URL for the bucket (custom domain), e.g. https://media.potterdoc.com
R2_PUBLIC_URL=

# Invitation email delivery via Resend SMTP
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=465
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=
EMAIL_USE_SSL=true
DEFAULT_FROM_EMAIL=noreply@potterdoc.com
INVITE_LINK_BASE_URL=https://potterdoc.com
