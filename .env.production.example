# Copy this file to .env on the droplet and fill in every value.
# Never commit .env to version control.

# Django secret key — generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=

# PostgreSQL password — choose a strong random string
POSTGRES_PASSWORD=

# The hostname of your droplet (no protocol, no trailing slash)
# e.g. myapp.example.com  or  123.45.67.89
ALLOWED_HOST=

# The full origin URL that the browser will use to reach the app
# e.g. https://myapp.example.com  or  http://123.45.67.89:8000
APP_ORIGIN=

# Google OAuth (optional — leave blank to disable Google sign-in)
# GOOGLE_OAUTH_CLIENT_ID is used by Django at runtime to verify Google JWTs.
# VITE_GOOGLE_CLIENT_ID is baked into the JS bundle at CI build time via the
# VITE_GOOGLE_CLIENT_ID GitHub Actions secret — it does not belong in this file.
GOOGLE_OAUTH_CLIENT_ID=

# Cloudinary image storage (optional — leave blank if not using)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=
CLOUDINARY_PUBLIC_UPLOAD_FOLDER=
CLOUDINARY_UPLOAD_PRESET=
