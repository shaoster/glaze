        "tests/test_cloudinary_upload_signature.py",
    ],
    main = "//tools:pytest_main.py",
    args = [
        "api/tests/test_admin_exports.py",
        "api/tests/test_cloudinary_image_widget.py",
        "api/tests/test_cloudinary_upload_signature.py",
    ],
