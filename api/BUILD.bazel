    "//:workflow_files",
    "//:fixtures",
    "//:pytest_ini",
    "//backend:backend_test_settings",
    ":migrations",
    ":api_static",
]

_TEST_ENV = {
    "DJANGO_SETTINGS_MODULE": "backend.test_settings",
    "GLAZE_DEV_BOOTSTRAP": "0",
