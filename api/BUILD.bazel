load("@rules_python//python:defs.bzl", "py_library", "py_test")
load("@pip//:requirements.bzl", "requirement")

# ── API library ───────────────────────────────────────────────────────────────
# All non-test, non-migration source files. Depends on backend_lib (Django
# settings/URL conf) and the workflow YAML files read at import time.

py_library(
    name = "api_lib",
    srcs = glob(
        ["**/*.py"],
        exclude = [
            "tests/**",
            "migrations/**",
            "**/test_*.py",
        ],
    ),
    data = ["//:workflow_files"],
    deps = [
        "//backend:backend_lib",
    ],
    visibility = ["//visibility:public"],
)

# Migrations are data, not importable library code: they're discovered and
# applied by Django at runtime, not imported by application logic.
filegroup(
    name = "migrations",
    srcs = glob(["migrations/**/*.py"]),
    visibility = ["//visibility:public"],
)

# ── Shared test infrastructure ────────────────────────────────────────────────

_TEST_DEPS = [
    ":api_lib",
    requirement("pytest"),
    requirement("pytest-django"),
    requirement("pytest-env"),
    requirement("pytest-cov"),
]

_TEST_DATA = [
    "//:workflow_files",
    "//:fixtures",
    "//:pytest_ini",
    ":migrations",
]

_TEST_ENV = {"DJANGO_SETTINGS_MODULE": "backend.test_settings"}

_CONFTEST = [
    "tests/__init__.py",
    "tests/conftest.py",
    "//tools:pytest_main.py",
]

# ── Granular API test targets ─────────────────────────────────────────────────
# Each target covers a coherent slice of the API so that changing one file
# only re-runs the tests that could be affected.

py_test(
    name = "api_workflow_test",
    size = "medium",
    srcs = _CONFTEST + [
        "tests/test_workflow_helpers.py",
        "tests/test_workflow_globals.py",
        "tests/test_additional_fields.py",
    ],
    main = "//tools:pytest_main.py",
    args = [
        "api/tests/test_workflow_helpers.py",
        "api/tests/test_workflow_globals.py",
        "api/tests/test_additional_fields.py",
    ],
    data = _TEST_DATA,
    deps = _TEST_DEPS,
    env = _TEST_ENV,
)

py_test(
    name = "api_model_test",
    size = "medium",
    srcs = _CONFTEST + [
        "tests/test_model_factory.py",
        "tests/test_globals.py",
        "tests/test_utils.py",
    ],
    main = "//tools:pytest_main.py",
    args = [
        "api/tests/test_model_factory.py",
        "api/tests/test_globals.py",
        "api/tests/test_utils.py",
    ],
    data = _TEST_DATA,
    deps = _TEST_DEPS,
    env = _TEST_ENV,
)

py_test(
    name = "api_piece_test",
    size = "medium",
    srcs = _CONFTEST + [
        "tests/test_pieces_create.py",
        "tests/test_pieces_list.py",
        "tests/test_piece_detail.py",
        "tests/test_piece_states.py",
        "tests/test_patch_current_state.py",
        "tests/test_sealed_state.py",
        "tests/test_analysis.py",
    ],
    main = "//tools:pytest_main.py",
    args = [
        "api/tests/test_pieces_create.py",
        "api/tests/test_pieces_list.py",
        "api/tests/test_piece_detail.py",
        "api/tests/test_piece_states.py",
        "api/tests/test_patch_current_state.py",
        "api/tests/test_sealed_state.py",
        "api/tests/test_analysis.py",
    ],
    data = _TEST_DATA,
    deps = _TEST_DEPS,
    env = _TEST_ENV,
)

py_test(
    name = "api_auth_test",
    size = "medium",
    srcs = _CONFTEST + [
        "tests/test_auth.py",
    ],
    main = "//tools:pytest_main.py",
    args = ["api/tests/test_auth.py"],
    data = _TEST_DATA,
    deps = _TEST_DEPS,
    env = _TEST_ENV,
