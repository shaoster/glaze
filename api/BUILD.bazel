py_test(
    name = "api_glaze_test",
    size = "medium",
    srcs = _CONFTEST + [
        "tests/test_glaze_combination.py",
        "tests/test_glaze_combination_admin.py",
        "tests/test_glaze_combination_picker.py",
        "tests/test_manual_square_crop_import.py",
