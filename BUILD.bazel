    visibility = ["//visibility:public"],
)

js_library(
    name = "workflow_js",
    srcs = ["workflow.yml"],
    visibility = ["//visibility:public"],
)

filegroup(
    name = "user_preferences_files",
    srcs = [
        "user_preferences.schema.yml",
        "user_preferences.yml",
    ],
    visibility = ["//visibility:public"],
)

js_library(
    name = "user_preferences_js",
    srcs = ["user_preferences.yml"],
    visibility = ["//visibility:public"],
)

filegroup(
    name = "tutorials_files",
    srcs = [
        "tutorials.schema.yml",
        "tutorials.yml",
    ],
    visibility = ["//visibility:public"],
)

