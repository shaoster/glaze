# ── Lint tool binaries (used by lint.bzl aspects) ─────────────────────────────

# ruff ships as a native binary wheel with no entry_points.txt; use the
# pre-built binary from aspect_rules_lint instead of py_console_script_binary.
alias(
    name = "ruff",
    actual = "@aspect_rules_lint//lint:ruff",
    visibility = ["//visibility:public"],
)

# ── OCI container image ───────────────────────────────────────────────────────
#
# bazel build //:image        — assemble the OCI image locally
# bazel run   //:push         — push to ghcr.io/shaoster/glaze:<tag>
#
# Image layout:
#   /appcontainer_entrypoint   Bazel launcher for the runtime image
#   /appcontainer_entrypoint.runfiles/_main
#                              Django project root plus repo-owned assets
#   /appcontainer_entrypoint.runfiles/.../site-packages
#                              uv-synced runtime deps
#   /app/version.txt           Build metadata read by backend.otel
#   /appcontainer_entrypoint.runfiles/_main/staticfiles
#                              collected static assets (built by staticfiles_tar)

py_binary(
    name = "container_entrypoint",
    srcs = [
        "container_entrypoint.py",
        "manage.py",
    ],
    data = [
        ":container_runtime_files",
        "//:tutorials_files",
        "//:user_preferences_files",
        "//web:web_build",
    ],
    main = "container_entrypoint.py",
    deps = [
        "//api:api_lib",
        "//backend:backend_lib",
        "@pypi//gunicorn",
        "@pypi//uvicorn",
    ],
)

filegroup(
    name = "container_runtime_files",
    srcs = [
        "docker-entrypoint.sh",
    ] + glob(
        ["fixtures/**"],
        allow_empty = True,
    ) + glob(
        ["assets/showcase_music/**"],
        allow_empty = True,
    ) + glob(
        ["assets/fonts/**"],
        allow_empty = False,
    ),
    visibility = ["//visibility:public"],
)

# Layer the Django runtime directly from the py_binary runfiles. This keeps the
# OCI image hermetic and avoids any host-python dependency from rules_pkg.
py_image_layer(
    name = "image_layers",
    binary = ":container_entrypoint",
    layer_groups = {
        "web": ".*web/dist/.*",
    },
    root = "/app",
)

# Static files layer — run collectstatic at build time so container startup
# doesn't block on it. Needs site-packages (DRF assets) + app source.
genrule(
    name = "staticfiles_tar",
    srcs = [
        ":image_layers",
    ],
    outs = ["staticfiles.tar"],
    cmd = """
        set -e
        tmp=$$(mktemp -d)
        for layer in $(locations :image_layers); do
            tar -xf "$$layer" -C "$$tmp"
        done
        entrypoint="$$tmp/appcontainer_entrypoint"
        OUT_TAR="$$PWD/$@"
        export DJANGO_SETTINGS_MODULE=backend.settings
        export SECRET_KEY=buildtime-placeholder
        "$$entrypoint" collectstatic --no-input
        tar -C "$$tmp" -cf "$$OUT_TAR" appcontainer_entrypoint.runfiles/_main/staticfiles
        rm -rf "$$tmp"
    """,
    tags = ["no-sandbox"],
)

genrule(
    name = "version_txt",
    srcs = [],
    outs = ["version.txt"],
    # Workspace status variables are not Make vars; must read stable-status.txt directly.
    cmd = "grep 'STABLE_GIT_COMMIT' bazel-out/stable-status.txt | awk '{print $$2}' > $@",
    stamp = 1,
)

pkg_tar(
    name = "version_tar",
    srcs = [":version_txt"],
    package_dir = "/app",
)

oci_image(
    name = "image",
    base = "@python312_slim",
    entrypoint = [
        "/bin/bash",
        "/appcontainer_entrypoint.runfiles/_main/docker-entrypoint.sh",
    ],
    env = {
        "PYTHONPATH": "/app:/app/site-packages",
        "PYTHONDONTWRITEBYTECODE": "1",
        "PYTHONUNBUFFERED": "1",
        "DJANGO_SETTINGS_MODULE": "backend.settings",
        # Limit CPU contention and prevent deadlocks in multi-worker environments
        "OMP_NUM_THREADS": "1",
        "MKL_NUM_THREADS": "1",
        "ONNXRUNTIME_INTER_OP_NUM_THREADS": "1",
        "ONNXRUNTIME_INTRA_OP_NUM_THREADS": "1",
    },
    exposed_ports = ["8000/tcp"],
    tars = [
        ":image_layers",
        ":staticfiles_tar",
        ":version_tar",
    ],
    workdir = "/appcontainer_entrypoint.runfiles/_main",
)

oci_push(
    name = "push",
    image = ":image",
    repository = "ghcr.io/shaoster/glaze",
    # Tag is set at push time via --tag flag or OCI_TAG env var.
    # Example: bazel run //:push -- --tag $(git rev-parse --short HEAD)
)

# passwd/group layers for the celery worker image.
# rules_distroless generates /etc/passwd and /etc/group as additive OCI layers,
# appending celery (uid/gid 1001) without clobbering existing base image users.
passwd(
    name = "celery_passwd",
    entries = [
        {
            "username": "celery",
            "uid": 1001,
            "gid": 1001,
            "gecos": [],
            "home": "/home/celery",
            "shell": "/usr/sbin/nologin",
        },
    ],
)

group(
    name = "celery_group",
    entries = [
        {
            "name": "celery",
            "gid": 1001,
        },
    ],
)

oci_image(
    name = "celery_worker_image",
    base = ":image",
    entrypoint = [
        "/appcontainer_entrypoint",
        "celery",
        "-A",
        "backend",
        "worker",
        "-l",
        "INFO",
    ],
    tars = [
        ":celery_passwd",
        ":celery_group",
    ],
    user = "celery",
)

oci_push(
    name = "push_worker",
    image = ":celery_worker_image",
    repository = "ghcr.io/shaoster/glaze-worker",
)  # Load the freshly-built image into the local docker daemon so CI (and devs)

# can `docker compose up` against it without a registry round-trip.
# `bazel run //:load` tags it as ghcr.io/shaoster/glaze:latest, matching the
# image reference in docker-compose.yml.
oci_load(
    name = "load",
    image = ":image",
    repo_tags = ["ghcr.io/shaoster/glaze:latest"],
)

# ── Kubernetes manifest validation ───────────────────────────────────────────

filegroup(
    name = "k3s_manifests",
    srcs = glob(["infra/k3s/*.yaml"]),
    visibility = ["//visibility:public"],
)
