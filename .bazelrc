# ── Common ────────────────────────────────────────────────────────────────────
common --enable_bzlmod
common --experimental_merged_skyframe_analysis_execution
build --workspace_status_command=tools/workspace_status.sh
common --spawn_strategy=local
build --incompatible_enable_cc_toolchain_resolution

# Coverage exclude tags
coverage --test_tag_filters=-no-coverage
# We don't care about gcov. We don't have any C++ code.
coverage --test_env=IGNORE_COVERAGE_COLLECTION_FAILURES=1


# ── Lint (bazel build --config=lint //...) ────────────────────────────────────
# ruff runs as an aspect over py_library targets (incremental).
# eslint runs as //web:eslint_check (standalone, tagged "lint") — the aspect
#   form does not correctly apply to js_library targets.
# mypy runs as //api:api_mypy (tagged "lint").
# tsc runs as //web:tsc_check (tagged "lint").
build:lint --aspects //:lint.bzl%ruff_aspect
build:lint --output_groups=+rules_lint_human
build:lint --keep_going

# ── CI ────────────────────────────────────────────────────────────────────────
# Cache Bazel outputs between CI runs using GitHub Actions cache as the
# backend. Set BAZEL_REMOTE_CACHE_URL in the repository's action secrets to
# enable a proper remote cache instead.
build:ci --announce_rc
build:ci --show_timestamps
build:ci --bes_results_url=https://app.buildbuddy.io/invocation/
build:ci --bes_backend=grpcs://remote.buildbuddy.io
common:ci --remote_cache=grpcs://remote.buildbuddy.io
common:ci --remote_cache_compression
common:ci --remote_timeout=10m
common:ci --nolegacy_important_outputs

# GHA specific optimizations: cache external repositories and limit resources
# to prevent OOM/swapping on standard runners.
common:ci --repository_cache=~/.cache/bazel-repo
common:ci --remote_download_toplevel
build:ci --local_ram_resources=5120
build:ci --local_cpu_resources=2
