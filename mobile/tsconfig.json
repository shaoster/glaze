{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@common/*": ["../frontend_common/src/*"]
    }
  },
  "include": [
    "App.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "../frontend_common/src/types.ts",
    "../frontend_common/src/api.ts",
    "../frontend_common/src/workflow.ts",
    "../frontend_common/src/yaml.d.ts"
  ]
}
